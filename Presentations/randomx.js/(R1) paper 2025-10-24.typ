    ```yasm
        add rax, rbx      ; (1) a = a + b
        imul rcx, rdx     ; (2) c = c * d
        sub rbx, 5        ; (3) b = b - 5
    ```
    #uncover((2, 3, 4, 5, 6, 7))[
      ```yasm
          ; (1) (2) (3) executed all at once (superscalar)
      ```
    ]
    ```yasm
        and rax, rcx      ; (4) a = a & c
        cmp rbx, 0        ; (5) test b with 0
    ```
    #uncover((3, 4, 5, 6, 7))[
