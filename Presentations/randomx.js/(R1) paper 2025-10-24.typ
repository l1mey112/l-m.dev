        add rax, rbx      ; (1) a = a + b
        imul rcx, rdx     ; (2) c = c * d
        and rax, rcx      ; (4) a = a & c

        sub rbx, 5        ; (3) b = b - 5
        cmp rbx, 0        ; (5) test b with 0
